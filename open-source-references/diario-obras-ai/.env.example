GEMINI_API_KEY=AIzaSyDisIxWiWTybq48BEWcQ91aEVPIjsX5dNo

# ===== CONFIGURAÇÕES DO BACKEND =====
# Tamanho máximo de upload (em bytes)
# Padrão: 10MB = 10485760 bytes
MAX_UPLOAD_SIZE=10485760

# Extensões de arquivo permitidas (separadas por vírgula)
ALLOWED_EXTENSIONS=png,jpg,jpeg,webp,mp3,wav,m4a

# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
