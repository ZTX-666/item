# Application
APP_ENV=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite+aiosqlite:///./ppe_detection.db
# DATABASE_URL=postgresql+asyncpg://ppe:ppe@db:5432/ppe_detection

# Model
MODEL_PATH=Model/ppe.pt
DETECTION_CONFIDENCE=0.5

# Alert timing (seconds)
ALERT_COOLDOWN_SECONDS=10
VIOLATION_PERSIST_SECONDS=10

# Email alerts (Gmail — requires App Password)
SENDER_EMAIL=your_email@gmail.com
RECEIVER_EMAIL=receiver_email@example.com
EMAIL_PASSWORD=your_app_password

# Optional: Slack webhook
SLACK_WEBHOOK_URL=

# Optional: Generic webhook
WEBHOOK_URL=
