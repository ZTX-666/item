<Window x:Class="WacliDesktop.HiAgentBridgeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HiAgent 云端对接"
        Width="720" Height="560" MinWidth="640" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/app-icon.ico"
        Background="{StaticResource SgBgBrush}">
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" TextWrapping="Wrap" FontSize="14" Foreground="{StaticResource SgMutedBrush}" Margin="4,0,4,8">
      一键启动本机 API + 内网穿透，生成 HiAgent 可用的公网地址与请求头。关闭本窗口后服务可继续运行，用「停止对接」结束。
    </TextBlock>

    <Border Grid.Row="1" Style="{StaticResource SgCard}" Padding="10" Margin="0,0,0,8">
      <StackPanel>
        <TextBlock Text="对接资源（可复制到 HiAgent）" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="公网地址" VerticalAlignment="Center" Margin="0,4"/>
          <TextBox Grid.Row="0" Grid.Column="1" x:Name="PublicUrlBox" IsReadOnly="True" Margin="4,4"/>
          <Button Grid.Row="0" Grid.Column="2" Content="复制" Click="CopyPublicUrl_Click" Margin="4,4" Padding="10,4"/>

          <TextBlock Grid.Row="1" Grid.Column="0" Text="API Key" VerticalAlignment="Center" Margin="0,4"/>
          <TextBox Grid.Row="1" Grid.Column="1" x:Name="ApiKeyBox" Margin="4,4"/>
          <Button Grid.Row="1" Grid.Column="2" Content="换新" Click="RegenKey_Click" Margin="4,4" Padding="10,4"/>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="状态" VerticalAlignment="Center" Margin="0,4"/>
          <TextBlock Grid.Row="2" Grid.Column="1" x:Name="StatusLine" Grid.ColumnSpan="2" Margin="4,4"
                     TextWrapping="Wrap"/>

          <TextBlock Grid.Row="3" Grid.Column="0" Text="测试 URL" VerticalAlignment="Top" Margin="0,4"/>
          <TextBox Grid.Row="3" Grid.Column="1" x:Name="TestUrlBox" IsReadOnly="True" Margin="4,4"
                   TextWrapping="Wrap" MinHeight="44"/>
          <Button Grid.Row="3" Grid.Column="2" Content="复制" Click="CopyTestUrl_Click" Margin="4,4" Padding="10,4"/>
        </Grid>
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Style="{StaticResource SgCard}" Padding="8">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="运行日志" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                 BorderThickness="0" Background="Transparent"/>
      </DockPanel>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button x:Name="BtnStart" Content="一键启动对接" Style="{StaticResource PrimaryButton}" Click="Start_Click" Width="120"/>
      <Button x:Name="BtnStop" Content="停止对接" Style="{StaticResource DangerButton}" Click="Stop_Click" Width="96" IsEnabled="False"/>
      <Button Content="复制全部配置" Click="CopyAll_Click" Width="110"/>
      <Button x:Name="BtnClose" Content="关闭" Click="Close_Click" Width="72"/>
    </StackPanel>
  </Grid>
</Window>
