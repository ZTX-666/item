CHITUNG_CENTER_HOST=127.0.0.1
CHITUNG_CENTER_PORT=8999

AGENT_TOOLBOX_BASE_URL=http://127.0.0.1:8899

# Cloud LLM gateway. Only minimal, sanitized context should be sent.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Optional aliases. When LLM_* is empty, Chitung Center can reuse an existing
# GLM/Zhipu/DocMate key and default to the Zhipu chat-completions endpoint.
GLM_API_KEY=
ZHIPU_API_KEY=
ZHIPUAI_API_KEY=
DOCMATE_API_KEY=
DOCMATE_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
DOCMATE_MODEL=glm-5.1

CHITUNG_DATA_DIR=./data
CHITUNG_SKILLS_DIR=./skills
CHITUNG_WORKFLOWS_DIR=./workflows
CHITUNG_AUDIT_LOG=./data/audit.jsonl
RAG_CHROMA_DIR=./data/rag_chroma
RAG_META_PATH=./data/rag_meta.json
RAG_UPLOAD_DIR=./data/rag_uploads
LLM_EMBEDDING_BASE_URL=
LLM_EMBEDDING_MODEL=
SECUREEYE_BASE_URL=
SECUREEYE_API_KEY=
SECUREEYE_MODEL=glm-4.5v
SECUREEYE_TIMEOUT_SECONDS=60
SECUREEYE_MAX_CONCURRENCY=1
SECUREEYE_MAX_TARGETS_PER_CAMERA=2
FFMPEG_BIN=
TABLE_MAPPING_SCRIPT_DIR=
TABLE_MAPPING_NODE_BIN=node
TABLE_MAPPING_TIMEOUT_SECONDS=180

# Feishu Open Platform app credentials for SDK long-connection events.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_API_BASE_URL=https://open.feishu.cn
FEISHU_LONG_CONNECTION_LOG_LEVEL=INFO
# Optional. If set, group messages only route when this bot is mentioned.
FEISHU_BOT_OPEN_ID=
FEISHU_BOT_NAMES=赤瞳,赤瞳机器人

# Future software adapters are registered but disabled by default.
ENABLE_FEISHU_ADAPTER=false
ENABLE_ZHT_ADAPTER=false
ENABLE_CHITONG_LINGXUN_ADAPTER=false
ENABLE_DOCMATE_ADAPTER=false
ENABLE_YAOYAO_HUIDU_ADAPTER=false
ENABLE_OPENCLAW_ADAPTER=false
