CHITUNG_CENTER_HOST=127.0.0.1
CHITUNG_CENTER_PORT=8999

AGENT_TOOLBOX_BASE_URL=http://127.0.0.1:8899

# Cloud LLM gateway. Only minimal, sanitized context should be sent.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

CHITUNG_DATA_DIR=./data
CHITUNG_SKILLS_DIR=./skills
CHITUNG_WORKFLOWS_DIR=./workflows
CHITUNG_AUDIT_LOG=./data/audit.jsonl
RAG_CHROMA_DIR=./data/rag_chroma
RAG_META_PATH=./data/rag_meta.json
RAG_UPLOAD_DIR=./data/rag_uploads
LLM_EMBEDDING_BASE_URL=
LLM_EMBEDDING_MODEL=
TABLE_MAPPING_SCRIPT_DIR=
TABLE_MAPPING_NODE_BIN=node
TABLE_MAPPING_TIMEOUT_SECONDS=180

# Future software adapters are registered but disabled by default.
ENABLE_FEISHU_ADAPTER=false
ENABLE_ZHT_ADAPTER=false
ENABLE_CHITONG_LINGXUN_ADAPTER=false
ENABLE_DOCMATE_ADAPTER=false
ENABLE_YAOYAO_HUIDU_ADAPTER=false
ENABLE_OPENCLAW_ADAPTER=false
