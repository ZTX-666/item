{
  "display_name": "每日风险简报",
  "description": "汇总香港天气、官方安全更新、新闻舆情与工伤风险，生成每日外部风险简报。",
  "intents": ["weather_news_risk"],
  "triggers": ["简报", "舆情", "新闻", "外部风险", "工伤意外", "监管", "预警", "外面", "每日简报"],
  "example_prompts": [
    "今天外面有什么要留意的，帮我整理一版简报",
    "生成今日外部风险简报",
    "汇总天气和新闻里的安全风险"
  ],
  "version": 1,
  "sources": [
    {
      "id": "hko_weather",
      "name": "香港天文台开放数据",
      "type": "api",
      "category": "safe",
      "enabled": true,
      "adapter": "hko_weather",
      "urls": [
        "https://data.weather.gov.hk/weatherAPI/opendata/weather.php?dataType=warnsum&lang=tc",
        "https://data.weather.gov.hk/weatherAPI/opendata/weather.php?dataType=warningInfo&lang=tc"
      ],
      "allowed_fields": ["warning_code", "warning_message", "update_time"],
      "poll_interval_seconds": 1800,
      "reliability": "official_api"
    },
    {
      "id": "gov_press_rss",
      "name": "政府新闻公报 RSS",
      "type": "rss",
      "category": "safe",
      "enabled": true,
      "adapter": "government_rss",
      "urls": ["https://www.info.gov.hk/gia/rss/general_zh.xml"],
      "allowed_fields": ["title", "link", "published_at", "description"],
      "poll_interval_seconds": 3600,
      "reliability": "official_rss"
    },
    {
      "id": "labour_department",
      "name": "劳工处职安警示",
      "type": "html",
      "category": "official_public",
      "enabled": true,
      "adapter": "html_index",
      "urls": ["https://www.labour.gov.hk/tc/news/work_safety_alert.htm"],
      "allowed_fields": ["title", "link", "published_at", "snippet"],
      "poll_interval_seconds": 21600,
      "reliability": "official_html"
    },
    {
      "id": "buildings_department",
      "name": "屋宇署通告及新闻",
      "type": "html",
      "category": "official_public",
      "enabled": true,
      "adapter": "html_index",
      "urls": [
        "https://www.bd.gov.hk/tc/resources/codes-and-references/practice-notes-and-circular-letters/index_circulars.html",
        "https://www.bd.gov.hk/tc/whats-new/press-releases/index.html"
      ],
      "allowed_fields": ["title", "link", "published_at", "snippet"],
      "poll_interval_seconds": 21600,
      "reliability": "official_html"
    },
    {
      "id": "housing_authority",
      "name": "房屋署/房委会工地安全",
      "type": "html",
      "category": "official_public",
      "enabled": true,
      "adapter": "html_index",
      "urls": [
        "https://www.housingauthority.gov.hk/mini-site/site-safety/tc/publications/alerts/index.html"
      ],
      "allowed_fields": ["title", "link", "published_at", "snippet"],
      "poll_interval_seconds": 21600,
      "reliability": "official_html"
    },
    {
      "id": "development_bureau",
      "name": "发展局工务技术通告",
      "type": "html_pdf",
      "category": "official_public",
      "enabled": true,
      "adapter": "pdf_index",
      "urls": [
        "https://www.devb.gov.hk/tc/publications_and_press_releases/technical_circulars/technical_circulars_um/index.html"
      ],
      "allowed_fields": ["title", "link", "published_at", "snippet", "pdf_url"],
