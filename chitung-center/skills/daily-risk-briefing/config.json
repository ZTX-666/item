  ],
  "keyword_groups": [
    {
      "category": "construction_safety",
      "include": ["地盘", "地盤", "工地", "建造业", "建造業", "承建商", "劳工处", "勞工處", "职安", "職安"],
      "exclude": ["自杀", "自殺", "交通意外", "住宅坠楼", "住宅墮樓"],
      "default_severity": "medium",
      "context_required": true
    },
    {
      "category": "fatal_incident",
      "include": ["工业意外", "工業意外", "工伤", "工傷", "死亡", "不治", "压毙", "壓斃", "夹毙", "夾斃"],
      "exclude": ["自杀", "自殺"],
      "default_severity": "high",
      "context_required": true
    },
    {
      "category": "weather",
      "include": ["暴雨", "酷热", "酷熱", "台风", "颱風", "雷暴", "山泥倾泻", "山泥傾瀉"],
      "exclude": [],
      "default_severity": "medium",
      "context_required": false
    }
  ],
  "media_policy": {
    "enabled": false,
    "metadata_only": true,
    "no_detail_fetch": true,
    "no_paywall": true,
    "no_captcha": true,
    "max_frequency": "low",
    "max_items_per_source": 10
  },
  "severity_rules": [
    {
      "when": "official_source and fatal_incident",
      "severity": "critical"
    },
    {
      "when": "media_source and fatal_incident and construction_context",
      "severity": "high"
    },
    {
      "when": "weather_warning in ['WTCSGNL', 'WRAIN', 'WL']",
      "severity": "high"
    },
    {
      "when": "media_source and exclusion_context",
      "severity": "low"
    }
  ]
}
