<UserControl x:Class="WacliDesktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0" Grid.Column="0" Margin="0,0,4,0" Style="{StaticResource SgCard}" Padding="8">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
          <Button x:Name="BtnQrStart" Content="生成二维码" Style="{StaticResource PrimaryButton}" Click="BtnQrStart_Click"/>
          <Button x:Name="BtnAuthStop" Content="停止" Click="BtnAuthStop_Click"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" Text="方式一 · 二维码" Style="{StaticResource SgSectionTitle}"/>
        <TextBlock DockPanel.Dock="Top" Text="WhatsApp → 已连接的设备 → 连接设备"
                   Foreground="{StaticResource SgMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4"/>
        <Border Background="#fafafa" CornerRadius="6" BorderBrush="{StaticResource SgBorderBrush}" BorderThickness="1">
          <Image x:Name="QrImage" Stretch="Uniform" Margin="4" MaxHeight="180"/>
        </Border>
      </DockPanel>
    </Border>

    <Border Grid.Row="0" Grid.Column="1" Margin="4,0,0,0" Style="{StaticResource SgCard}" Padding="8">
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Top" Text="方式二 · 配对码" Style="{StaticResource SgSectionTitle}"/>
        <TextBlock DockPanel.Dock="Top" Text="如：+852 12345678"
                   Foreground="{StaticResource SgMutedBrush}" FontSize="12" Margin="0,0,0,4"/>
        <TextBox DockPanel.Dock="Top" x:Name="PhoneInput" Text="+852" Margin="0,0,0,4"/>
        <Button DockPanel.Dock="Top" x:Name="BtnPhoneStart" Content="获取配对码"
                Style="{StaticResource PrimaryButton}" Click="BtnPhoneStart_Click" HorizontalAlignment="Left"/>
        <Border Margin="0,8,0,0" Padding="8,6" Background="#fff8f8" CornerRadius="8"
                BorderBrush="{StaticResource SgPrimaryBrush}" BorderThickness="1">
          <StackPanel>
            <TextBlock Text="配对码（手机 WhatsApp → 关联设备 → 使用手机号关联）"
                       Foreground="{StaticResource SgMutedBrush}" FontSize="11" TextWrapping="Wrap"/>
            <TextBlock x:Name="PairingCodeText" Text="—" FontSize="32" FontFamily="Consolas"
                       FontWeight="Bold" Foreground="{StaticResource SgPrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap"/>
            <TextBlock x:Name="PairingHintText" Text="" FontSize="11"
                       Foreground="{StaticResource SgMutedBrush}" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
      </DockPanel>
    </Border>

    <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,4,0,0" Style="{StaticResource SgCard}" Padding="8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="88"/>
          <RowDefinition Height="64"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="会话与同步" Style="{StaticResource SgSectionTitle}"/>
        <WrapPanel Grid.Row="1" Margin="0,0,0,2">
          <Button Content="启动 sync" Click="BtnSyncStart_Click" Style="{StaticResource CompactButton}"/>
          <Button Content="停止 sync" Click="BtnSyncStop_Click" Style="{StaticResource CompactButton}"/>
          <Button Content="刷新" Click="BtnRefreshStatus_Click" Style="{StaticResource CompactButton}"/>
          <Button Content="退出登录" Style="{StaticResource DangerButton}" Click="BtnLogout_Click"/>
        </WrapPanel>
        <TextBox Grid.Row="2" x:Name="StatusBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                 FontFamily="Consolas" FontSize="11"/>
        <TextBox Grid.Row="3" x:Name="AuthLogBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                 FontFamily="Consolas" FontSize="11" Foreground="{StaticResource SgMutedBrush}" Margin="0,2,0,0"/>
      </Grid>
    </Border>
  </Grid>
</UserControl>
