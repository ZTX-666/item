<UserControl x:Class="WacliDesktop.Views.BrowseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:WacliDesktop.Helpers">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="96"/>
    </Grid.RowDefinitions>

    <WrapPanel Grid.Row="0">
      <Button Content="消息明细" Tag="message_detail" Click="Preset_Click" Style="{StaticResource CompactButton}"/>
      <Button Content="含附件" Tag="messages_with_attachment" Click="Preset_Click" Style="{StaticResource CompactButton}"/>
      <Button Content="聊天列表" Tag="chat_summary" Click="Preset_Click" Style="{StaticResource CompactButton}"/>
      <Button Content="消息数" Tag="message_count" Click="Preset_Click" Style="{StaticResource CompactButton}"/>
      <Button Content="附件数" Tag="attachment_count" Click="Preset_Click" Style="{StaticResource CompactButton}"/>
    </WrapPanel>

    <Grid Grid.Row="1" Margin="0,2,0,2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBox x:Name="SearchInput" Width="220" VerticalContentAlignment="Center" Margin="0,0,6,0"/>
        <TextBlock x:Name="DbPathHint" TextWrapping="Wrap" MaxWidth="420" FontSize="11"
                   Foreground="{StaticResource SgMutedBrush}" VerticalAlignment="Center"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button Content="导出数据库" Click="BtnExportDb_Click" Style="{StaticResource CompactButton}"/>
        <Button Content="加载数据库" Click="BtnLoadDb_Click" Style="{StaticResource CompactButton}"/>
        <Button Content="默认数据库" Click="BtnSetDefaultDb_Click" Style="{StaticResource CompactButton}"
                ToolTip="修改默认数据库存放根目录（用户目录下）"/>
        <Button Content="刷新" Click="BtnRefreshDb_Click" Style="{StaticResource CompactButton}"/>
        <Button Content="搜索" Style="{StaticResource PrimaryButton}" Click="BtnSearch_Click"/>
      </StackPanel>
    </Grid>

    <Border Grid.Row="2" Style="{StaticResource SgCard}" Padding="2">
      <Grid>
        <ListView x:Name="MessageListView" Style="{StaticResource CompactListView}"
                  h:GridViewFitHelper.AutoFitLastColumn="True"
                  SelectionMode="Single" SelectionChanged="MessageListView_SelectionChanged">
          <ListView.View>
            <GridView>
              <GridViewColumn Width="46">
                <GridViewColumn.Header>
                  <Grid Style="{StaticResource BrowseColumnHeaderGrid}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="项目"
                               Style="{StaticResource BrowseHeaderText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Style="{StaticResource BrowseHeaderFilterSpacer}"/>
                  </Grid>
                </GridViewColumn.Header>
                <GridViewColumn.CellTemplate>
                  <DataTemplate>
                    <Button Style="{StaticResource ProjectIconButton}" Click="ProjectItem_Click"
                            IsEnabled="{Binding CanOpenFile}" Tag="{Binding}">
                      <Image Source="{Binding Thumbnail}" Width="34" Height="34" Stretch="Uniform"/>
                    </Button>
                  </DataTemplate>
                </GridViewColumn.CellTemplate>
              </GridViewColumn>

              <GridViewColumn Width="92">
                <GridViewColumn.Header>
                  <Grid Style="{StaticResource BrowseColumnHeaderGrid}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="群组" Style="{StaticResource BrowseHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Style="{StaticResource FilterHeaderButton}"
                            Tag="GroupDisplay" Click="FilterHeader_Click"/>
                  </Grid>
                </GridViewColumn.Header>
                <GridViewColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding GroupDisplay}" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding GroupDisplay}" FontSize="12" VerticalAlignment="Center"/>
                  </DataTemplate>
                </GridViewColumn.CellTemplate>
              </GridViewColumn>

              <GridViewColumn Width="100" DisplayMemberBinding="{Binding MessageDate}">
                <GridViewColumn.Header>
                  <Grid Style="{StaticResource BrowseColumnHeaderGrid}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="日期" Style="{StaticResource BrowseHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Style="{StaticResource FilterHeaderButton}"
                            Tag="MessageDate" Click="FilterHeader_Click"/>
                  </Grid>
                </GridViewColumn.Header>
              </GridViewColumn>

              <GridViewColumn Width="96">
                <GridViewColumn.Header>
                  <Grid Style="{StaticResource BrowseColumnHeaderGrid}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ID" Style="{StaticResource BrowseHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Style="{StaticResource FilterHeaderButton}"
                            Tag="WhatsappId" Click="FilterHeader_Click"/>
                  </Grid>
                </GridViewColumn.Header>
                <GridViewColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding WhatsappId}" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding WhatsappId}" FontSize="12" VerticalAlignment="Center"/>
                  </DataTemplate>
                </GridViewColumn.CellTemplate>
              </GridViewColumn>

              <GridViewColumn Width="64" DisplayMemberBinding="{Binding SenderName}">
                <GridViewColumn.Header>
                  <Grid Style="{StaticResource BrowseColumnHeaderGrid}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="发送人" Style="{StaticResource BrowseHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Style="{StaticResource FilterHeaderButton}"
                            Tag="SenderName" Click="FilterHeader_Click"/>
                  </Grid>
                </GridViewColumn.Header>
              </GridViewColumn>

              <GridViewColumn Width="44" DisplayMemberBinding="{Binding AttachmentType}">
                <GridViewColumn.Header>
                  <Grid Style="{StaticResource BrowseColumnHeaderGrid}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="附件" Style="{StaticResource BrowseHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Style="{StaticResource FilterHeaderButton}"
                            Tag="AttachmentType" Click="FilterHeader_Click"/>
                  </Grid>
                </GridViewColumn.Header>
              </GridViewColumn>

              <GridViewColumn Width="44" DisplayMemberBinding="{Binding AttachmentStatus}">
                <GridViewColumn.Header>
                  <Grid Style="{StaticResource BrowseColumnHeaderGrid}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="状态" Style="{StaticResource BrowseHeaderText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Style="{StaticResource FilterHeaderButton}"
                            Tag="AttachmentStatus" Click="FilterHeader_Click"/>
                  </Grid>
                </GridViewColumn.Header>
              </GridViewColumn>

              <GridViewColumn Width="160">
                <GridViewColumn.Header>
                  <Grid Style="{StaticResource BrowseColumnHeaderGrid}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="消息" Style="{StaticResource BrowseHeaderText}" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Style="{StaticResource BrowseHeaderFilterSpacer}"/>
                  </Grid>
                </GridViewColumn.Header>
                <GridViewColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding MessageText}" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding MessageText}" FontSize="12" VerticalAlignment="Center"/>
                  </DataTemplate>
                </GridViewColumn.CellTemplate>
              </GridViewColumn>
            </GridView>
          </ListView.View>
        </ListView>
        <DataGrid x:Name="BrowseGrid" AutoGenerateColumns="True" IsReadOnly="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" Visibility="Collapsed"/>
      </Grid>
    </Border>

    <Border Grid.Row="3" Margin="0,2,0,0" Style="{StaticResource SgCard}" Padding="6">
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Top" Text="附件详情" Style="{StaticResource SgSectionTitle}" Margin="0"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <TextBox x:Name="AttachmentDetailBox" IsReadOnly="True" AcceptsReturn="True"
                   TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                   Foreground="{StaticResource SgMutedBrush}" BorderThickness="0" Background="Transparent"/>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <Popup x:Name="ColumnFilterPopup" StaysOpen="False" AllowsTransparency="True" Placement="Bottom">
      <Border Background="White" BorderBrush="{StaticResource SgBorderBrush}" BorderThickness="1"
              CornerRadius="6" Padding="8" MinWidth="180" MaxWidth="280">
        <Border.Effect>
          <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.12" Color="Black"/>
        </Border.Effect>
        <StackPanel>
          <TextBlock x:Name="FilterTitleText" FontWeight="SemiBold" FontSize="13"
                     Foreground="{StaticResource SgPrimaryBrush}" Margin="0,0,0,6"/>
          <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FilterOptionsPanel"/>
          </ScrollViewer>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="全选" Click="FilterSelectAll_Click" Style="{StaticResource CompactButton}" Padding="8,3"/>
            <Button Content="清除" Click="FilterClear_Click" Style="{StaticResource CompactButton}" Padding="8,3"/>
            <Button Content="确定" Click="FilterApply_Click" Style="{StaticResource PrimaryButton}" Padding="8,3"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Popup>
  </Grid>
</UserControl>
