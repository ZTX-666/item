<Window x:Class="WacliDesktop.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="赤瞳灵讯"
        Width="780"
        MinWidth="780" MaxWidth="780"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/app-icon.ico">

  <Border Background="{StaticResource SgBgBrush}" Padding="10">
    <Border Background="#F5F5F5" CornerRadius="12" BorderBrush="#DDDDDD" BorderThickness="1"
            ClipToBounds="False">
      <Border.Effect>
        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.12" Color="Black"/>
      </Border.Effect>
      <DockPanel LastChildFill="True">

        <!-- 页脚贴底 -->
        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="{StaticResource SgBorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,10" Margin="0">
          <Grid>
            <TextBlock Text="开发者：Sean Xu" FontSize="12" Foreground="#AAAAAA"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Button Content="配置环境" Style="{StaticResource FooterMiniButton}" Click="BtnEnvSetup_Click"/>
              <Button Content="耀耀工厂" Style="{StaticResource FooterMiniButton}" Click="BtnYaoyaoFactory_Click"/>
              <Button Content="帮助手册" Style="{StaticResource FooterMiniButton}" Click="BtnHelp_Click"/>
            </StackPanel>
          </Grid>
        </Border>

        <StackPanel DockPanel.Dock="Top">
          <Border Background="White" CornerRadius="12,12,0,0" Padding="8,6,8,5" Height="62" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
            <Grid Width="746" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Image Source="/Assets/banner-cscec.png" Stretch="Uniform"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <Border Background="{StaticResource SgHeaderGradient}" Padding="12,14,12,12" Margin="0">
            <StackPanel HorizontalAlignment="Center">
              <TextBlock Text="赤瞳灵讯" FontSize="30" FontWeight="Bold" Foreground="#FFE08A" HorizontalAlignment="Center"/>
              <TextBlock Text="登录配对 · 消息同步 · 数据浏览 · SQLite 查询 · 命令工具 · 赤瞳工具箱"
                         FontSize="12" Foreground="#F2DCDC" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
          </Border>

          <Border Style="{StaticResource SgStatusBar}" Margin="10,8,10,0" BorderThickness="0,0,0,1">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#E24B4A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="检测中…" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource SgTextBrush}" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="请选择下方板块进入功能" FontSize="12"
                         Foreground="{StaticResource SgMutedBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <UniformGrid Rows="2" Columns="3" Margin="10,10,10,8">
            <Button Style="{StaticResource ModuleTileButton}" Tag="login" Click="ModuleTile_Click" Margin="3">
              <StackPanel>
                <TextBlock Text="登录配对" Style="{StaticResource ModuleTileTitle}"/>
                <TextBlock Text="二维码 / 手机号 · sync 与附件下载" Style="{StaticResource ModuleTileDesc}"/>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource ModuleTileButton}" Tag="browse" Click="ModuleTile_Click" Margin="3">
              <StackPanel>
                <TextBlock Text="数据浏览" Style="{StaticResource ModuleTileTitle}"/>
                <TextBlock Text="消息明细 · 缩略图 · 群组 · 筛选" Style="{StaticResource ModuleTileDesc}"/>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource ModuleTileButton}" Tag="sql" Click="ModuleTile_Click" Margin="3">
              <StackPanel>
                <TextBlock Text="SQLite 查询" Style="{StaticResource ModuleTileTitle}"/>
                <TextBlock Text="表结构 · SELECT · 附件预览" Style="{StaticResource ModuleTileDesc}"/>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource ModuleTileButton}" Tag="console" Click="ModuleTile_Click" Margin="3">
              <StackPanel>
                <TextBlock Text="命令工具" Style="{StaticResource ModuleTileTitle}"/>
                <TextBlock Text="doctor · auth · sync · messages · chats …" Style="{StaticResource ModuleTileDesc}"/>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource ModuleTileButton}" Tag="toolbox" Click="ModuleTile_Click" Margin="3">
              <StackPanel>
                <TextBlock Text="赤瞳工具箱" Style="{StaticResource ModuleTileTitle}"/>
                <TextBlock Text="WhatsApp 搜索 · 隐患案例 · 表格模板" Style="{StaticResource ModuleTileDesc}"/>
              </StackPanel>
            </Button>
          </UniformGrid>
        </StackPanel>
      </DockPanel>
    </Border>
  </Border>
</Window>
