# AgentToolbox local configuration.
# Copy to .env ONLY if you need to override defaults.
#
# IMPORTANT: All path settings below are OPTIONAL. If you leave them unset,
# AgentToolbox automatically resolves them relative to the repository layout
# (see config.py), so it works out of the box on macOS, Linux, and Windows.
# Only set a path here if your folders live somewhere non-standard.

AGENT_TOOLBOX_HOST=127.0.0.1
AGENT_TOOLBOX_PORT=8899

# ── Optional path overrides (leave commented to use cross-platform defaults) ──
# Defaults resolve to sibling folders of agent-toolbox in this repository:
#   ../vlm-detection, ../rtmp-tools/rtmp_snapshot.py,
#   ../report-generators/generate_community_doc.py,
#   ../safety-policy-templates-20241025
#
# AGENT_TOOLBOX_ROOT=
# AGENT_TOOLBOX_WORKSPACE=
# VLM_DETECTION_DIR=
# RTMP_SNAPSHOT_SCRIPT=
# REPORT_SCRIPT=
# SAFETY_POLICY_TEMPLATES_DIR=
# SAFETY_DATABASE_PATH=
# YAOYAO_WORK_DIR=
# YAOYAO_MODEL_DIR=

# Interpreter used to run the external VLM / RTMP / report scripts.
VLM_PYTHON=python3
RTMP_PYTHON=python3
REPORT_PYTHON=python3
DEFAULT_RTMP_URL=rtmp://10.148.1.22/live/test

WHATSAPP_ARCHIVE_BASE_URL=http://127.0.0.1:8787

# WhatsApp wacli runtime.
# 方法一（Windows 发布包）：如果 publish3.0 与 agent-toolbox 同在项目根目录，
# 后端会自动探测 publish3.0\runtime\bin\wacli.exe。
# 如需显式指定，请取消下面三行注释并改成你的发布包绝对路径。
# WACLI_BIN=E:\publish3.0\runtime\bin\wacli.exe
# WACLI_WORKDIR=E:\publish3.0\runtime\data
# WACLI_STORE_DIR=E:\publish3.0\runtime\data

# Optional Feishu custom bot webhook for push notifications.
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# Optional Feishu app bot credentials for OpenAPI message/card/event integration.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_API_BASE_URL=https://open.feishu.cn

YAOYAO_PYTHON_BIN=
YAOYAO_WORKER_TIMEOUT=60

# SecureEye VLM large-model configuration (optional).
SECUREEYE_BASE_URL=https://api.openai.com/v1
SECUREEYE_API_KEY=
SECUREEYE_MODEL=gpt-4o
SECUREEYE_TIMEOUT_SECONDS=30
SECUREEYE_MAX_CONCURRENCY=4
YOLO_CONF_THRESHOLD=0.45
