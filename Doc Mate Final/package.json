{
  "name": "docmate",
  "private": true,
  "version": "4.1.37",
  "description": "DocMate 闪闪文档 - 便携桌面文稿修改助手",
  "author": "China Overseas",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "start": "electron ."
  },
  "dependencies": {
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@tiptap/vue-3": "^2.11.5",
    "@xenova/transformers": "^2.17.2",
    "docx": "^9.7.1",
    "mammoth": "^1.9.0",
    "marked": "^18.0.5",
    "vue": "^3.5.13",
    "electron": "^34.0.0"
  },
  "build": {
    "appId": "com.chinaconstruction.docmate",
    "productName": "DocMate闪闪文档",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/onnxruntime-node/**"
    ],
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/@xenova/transformers/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/mammoth/**/*",
      "node_modules/marked/**/*",
      "node_modules/docx/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "dist/闪闪文档.png",
      "signAndEditExecutable": false
    }
  }
}
