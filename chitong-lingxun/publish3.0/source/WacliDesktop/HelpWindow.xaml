<Window x:Class="WacliDesktop.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="帮助手册 · 赤瞳灵讯"
        Width="680" Height="560" MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/app-icon.ico"
        Background="{StaticResource SgBgBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource SgHeaderGradient}" Padding="12,8" CornerRadius="8">
      <TextBlock Text="帮助手册" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
    </Border>

    <Border Grid.Row="1" Margin="8" Style="{StaticResource SgCard}" Padding="10">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <TextBlock x:Name="HelpText" TextWrapping="Wrap" FontSize="14" LineHeight="22"
                   Foreground="{StaticResource SgTextBrush}"/>
      </ScrollViewer>
    </Border>

    <Button Grid.Row="2" Content="关闭" HorizontalAlignment="Right" Margin="8,0,8,8"
            Style="{StaticResource PrimaryButton}" Click="Close_Click" Width="88"/>
  </Grid>
</Window>
