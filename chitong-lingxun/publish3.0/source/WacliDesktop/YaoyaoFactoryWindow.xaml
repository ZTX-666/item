<Window x:Class="WacliDesktop.YaoyaoFactoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="耀耀工厂"
        Width="760" Height="640" MinWidth="680" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/app-icon.ico"
        Background="{StaticResource SgBgBrush}">
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource SgHeaderGradient}" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
      <TextBlock Text="耀耀工厂" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
    </Border>

    <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource SgMutedBrush}" Margin="4,0,4,8">
      将本机 wacli 数据推送到云服务器（出站 HTTPS）。云端部署接收 API 后，在耀耀工厂「创建数据通道」连接云 MySQL。详见 publish20/memory.md。
    </TextBlock>

    <TabControl Grid.Row="2" x:Name="MainTabs">
      <TabItem Header="云端同步">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="4">
            <Border Style="{StaticResource SgCard}" Padding="10" Margin="0,0,0,8">
              <StackPanel>
                <TextBlock Text="同步配置" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <TextBlock Grid.Row="0" Grid.Column="0" Text="API 地址" VerticalAlignment="Center" Margin="0,6"/>
                  <TextBox Grid.Row="0" Grid.Column="1" x:Name="ApiBaseUrlBox" Margin="4,4"
                           ToolTip="例如 https://sync.example.com"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="同步 Token" VerticalAlignment="Center" Margin="0,6"/>
                  <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="SyncTokenBox" Margin="4,4"/>

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="OwnerId" VerticalAlignment="Center" Margin="0,6"/>
                  <TextBox Grid.Row="2" Grid.Column="1" x:Name="OwnerIdBox" Margin="4,4"
                           ToolTip="用户标识，用于云上数据隔离"/>

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="同步档位" VerticalAlignment="Center" Margin="0,6"/>
                  <ComboBox Grid.Row="3" Grid.Column="1" x:Name="SyncTierCombo" Margin="4,4" SelectedIndex="0">
                    <ComboBoxItem Content="档位1：仅消息元数据（推荐试点）"/>
                    <ComboBoxItem Content="档位2：元数据 + 缩略图"/>
                    <ComboBoxItem Content="档位3：元数据 + 缩略图 + 原文件媒体"/>
                  </ComboBox>

                  <TextBlock Grid.Row="4" Grid.Column="0" Text="自动同步" VerticalAlignment="Center" Margin="0,6"/>
                  <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="4,4">
                    <CheckBox x:Name="AutoSyncCheck" Content="启用" VerticalAlignment="Center"/>
                    <TextBlock Text="间隔(分钟)" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <TextBox x:Name="IntervalBox" Width="48" Text="15"/>
                  </StackPanel>

                  <TextBlock Grid.Row="5" Grid.Column="0" Text="状态" VerticalAlignment="Top" Margin="0,6"/>
                  <TextBlock Grid.Row="5" Grid.Column="1" x:Name="CloudStatusLine" Margin="4,6" TextWrapping="Wrap"/>

                  <TextBlock Grid.Row="6" Grid.Column="0" Text="接口说明" VerticalAlignment="Top" Margin="0,6"/>
                  <TextBox Grid.Row="6" Grid.Column="1" x:Name="ApiHelpBox" IsReadOnly="True" Margin="4,4"
                           TextWrapping="Wrap" MinHeight="72" FontFamily="Consolas" FontSize="11"/>
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource SgCard}" Padding="8">
              <DockPanel MinHeight="180">
                <TextBlock DockPanel.Dock="Top" Text="同步日志" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="CloudLogBox" IsReadOnly="True" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                         BorderThickness="0" Background="Transparent"/>
              </DockPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="本机调试（可选）">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="4">
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SgMutedBrush}" Margin="0,0,0,8" FontSize="12">
              仅供开发联调：本机 API + cloudflared。生产环境请使用「云端同步」，勿暴露办公机到公网。
            </TextBlock>
            <Border Style="{StaticResource SgCard}" Padding="10" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="100"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="公网地址" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="PublicUrlBox" IsReadOnly="True" Margin="4,4"/>
                <Button Grid.Row="0" Grid.Column="2" Content="复制" Click="CopyPublicUrl_Click" Margin="4,4" Padding="10,4"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="API Key" VerticalAlignment="Center" Margin="0,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="LocalApiKeyBox" Margin="4,4"/>
                <Button Grid.Row="1" Grid.Column="2" Content="换新" Click="RegenLocalKey_Click" Margin="4,4" Padding="10,4"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="本机状态" VerticalAlignment="Center" Margin="0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LocalBridgeStatus" Grid.ColumnSpan="2" Margin="4,4" TextWrapping="Wrap"/>
              </Grid>
            </Border>
            <Border Style="{StaticResource SgCard}" Padding="8" MinHeight="120">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="本机调试日志" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="LocalLogBox" IsReadOnly="True" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                         BorderThickness="0" Background="Transparent"/>
              </DockPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="3" Margin="0,8,0,0">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="BtnSaveCloud" Content="保存配置" Click="SaveCloud_Click" Width="88"/>
        <Button x:Name="BtnTestCloud" Content="测试连接" Click="TestCloud_Click" Width="88"/>
        <Button x:Name="BtnSyncNow" Content="立即同步" Style="{StaticResource PrimaryButton}" Click="SyncNow_Click" Width="96"/>
        <Button Content="复制接口说明" Click="CopyApiHelp_Click" Width="110"/>
        <Button x:Name="BtnStartLocal" Content="启动本机调试" Click="StartLocal_Click" Width="110"/>
        <Button x:Name="BtnStopLocal" Content="停止本机" Click="StopLocal_Click" Width="80" IsEnabled="False"/>
        <Button Content="关闭" Click="Close_Click" Width="64"/>
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>
